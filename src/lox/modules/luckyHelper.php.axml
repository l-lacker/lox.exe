      <elementLoadContent object="luckyqansw3_future" object-type="variable" path="'https://l-lacker.ru/app/lucky/config.php?mode=gq&amp;n='.$GLOBALS['luckyqc'].'&amp;subq=3'" path-type="expr" sync="" sync-type=""/>
