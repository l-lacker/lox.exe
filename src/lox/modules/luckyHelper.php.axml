      <elementLoadContent object="luckyqlab_future" object-type="variable" path="'https://l-lacker.ru/app/lucky/config.php?mode=gq&amp;n='.$GLOBALS['luckyqc'].'&amp;subq=0'" path-type="expr" sync="" sync-type=""/>
      <elementLoadContent object="luckyqansw1_future" object-type="variable" path="'https://l-lacker.ru/app/lucky/config.php?mode=gq&amp;n='.$GLOBALS['luckyqc'].'&amp;subq=1'" path-type="expr" sync="" sync-type=""/>
