<root>
  <class name="luckyHelper">
    
  
  
  
  <method name="doLuckym1Action">
      <ifVar method="equals" method-type="" name="luckymode" name-type="" not="" not-type="" value="fiveslides" value-type="string"/>
      <openBlock/>
      <ifVar method="equals" method-type="" name="luckyslide" name-type="" not="" not-type="" value="" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;image3-&gt;image = $this-&gt;tempimg1-&gt;image" expr-type="expr"/>
      <setVar name="luckyslide" name-type="" value="2" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="luckyslide" name-type="" not="" not-type="" value="2" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;image3-&gt;image = $this-&gt;tempimg2-&gt;image" expr-type="expr"/>
      <setVar name="luckyslide" name-type="" value="3" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="luckyslide" name-type="" not="" not-type="" value="3" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;image3-&gt;image = $this-&gt;tempimg3-&gt;image" expr-type="expr"/>
      <setVar name="luckyslide" name-type="" value="4" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="luckyslide" name-type="" not="" not-type="" value="4" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;image3-&gt;image = $this-&gt;tempimg4-&gt;image" expr-type="expr"/>
      <setVar name="luckyslide" name-type="" value="5" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="luckyslide" name-type="" not="" not-type="" value="5" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;image3-&gt;image = $this-&gt;tempimg5-&gt;image" expr-type="expr"/>
      <setVar name="luckyslide" name-type="" value="" value-type="string"/>
      <exit/>
      <closeBlock/>
      <closeBlock/>
    </method>
  <method name="doCommentsAction">
      <ifVar method="equals" method-type="" name="luckycomms" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <elementLoadContent object="labelAlt" object-type="object" path="https://l-lacker.ru/app/lucky/randcomm.php" path-type="string" sync="" sync-type=""/>
