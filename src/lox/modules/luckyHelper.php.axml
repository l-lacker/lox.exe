      <elementLoadContent object="imageAlt" object-type="object" path="res://.data/img/llucky-overlay6.png" path-type="string" sync="" sync-type=""/>
      <elementSetText object="button9" object-type="object" relative="" relative-type="" value="Включить" value-type="string"/>
      <fadeTo continue="1" continue-type="" duration="1" duration-type="integer" object="panel" object-type="object" value="0" value-type="float"/>
      <setVar name="luckycomms" name-type="" value="0" value-type="string"/>
      <setVar name="unlockluckystore" name-type="" value="1" value-type="string"/>
      <phpLine expr="$this-&gt;playerMain-&gt;stop()" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMainPitch-&gt;stop()" expr-type="expr"/>
      <playMedia id="luckyendmasic" id-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="luckymode" name-type="" not="" not-type="" value="ingameprepare" value-type="string"/>
      <openBlock/>
      <setVar name="luckymode" name-type="" value="" value-type="string"/>
      <appendVar asString="" asString-type="" name="luckyqc" name-type="" value="1" value-type="string"/>
      <setVar name="luckyprikol1" name-type="" value="'https://l-lacker.ru/app/lucky/bg/'.$GLOBALS['luckyqc'].'.png'" value-type="expr"/>
      <elementLoadContent object="tempimg5" object-type="object" path="$GLOBALS['luckyprikol1']" path-type="expr" sync="" sync-type=""/>
      <ifVar method="equals" method-type="" name="luckyqc" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;image3-&gt;image = $this-&gt;tempimg5-&gt;image" expr-type="expr"/>
