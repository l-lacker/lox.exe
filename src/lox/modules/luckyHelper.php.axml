  <method name="doTimerAction">
      <phpLine expr="$volumeow2 = $GLOBALS['vt_volcol']/100" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerVoice-&gt;volume = $volumeow2" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerVoiceQ-&gt;volume = $volumeow2" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerVoiceQ2-&gt;volume = $volumeow2" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerTicks-&gt;volume = $volumeow2" expr-type="expr"/>
      <ifVar method="equals" method-type="" name="luckypitched" name-type="" not="1" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <phpLine expr="$volumeow = 35/$GLOBALS['vt_volcol']" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMainPitch-&gt;volume = 0.0" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMain-&gt;volume = $volumeow" expr-type="expr"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <phpLine expr="$volumeow = 35/$GLOBALS['vt_volcol']" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMain-&gt;volume = 0.0" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMainPitch-&gt;volume = $volumeow" expr-type="expr"/>
      <closeBlock/>
    </method>
  </class>
