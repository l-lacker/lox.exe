      <setVar name="luckycount2" name-type="" value="luckycount" value-type="variable"/>
      <closeBlock/>
      <phpLine expr="$luckyprikol11 = 'https://l-lacker.ru/app/lucky/voice/'.$GLOBALS['luckyqc'].'.mp3'" expr-type="expr"/>
      <setVar name="luckyprikol11" name-type="" value="luckyprikol11" value-type="variable"/>
