  <method name="doLuckyHelperAction">
      <ifVar method="equals" method-type="" name="luckymode" name-type="" not="" not-type="" value="gameend" value-type="string"/>
      <openBlock/>
      <setVar name="luckymode" name-type="" value="" value-type="string"/>
