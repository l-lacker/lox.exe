<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<root>
  <class name="rgbaccent">
    <method name="doRgbaccentAction">
      <ifVar method="equals" method-type="" name="vtb_rgbaccent" name-type="" not="" not-type="" value="default" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;fillColor = &quot;1a3399&quot;" expr-type="expr"/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;strokeColor = &quot;1a3399&quot;" expr-type="expr"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccent" name-type="" not="" not-type="" value="webos" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;fillColor = &quot;b20148&quot;" expr-type="expr"/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;strokeColor = &quot;b20148&quot;" expr-type="expr"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccent" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="vtb_rgbaccenttick" name-type="" value="1" value-type="string"/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccenttick" name-type="" not="" not-type="" value="7" value-type="string"/>
      <openBlock/>
      <setVar name="vtb_rgbaccenttick" name-type="" value="1" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccenttick" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
