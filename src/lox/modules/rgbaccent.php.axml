      <phpLine expr="$this-&gt;magicrect_control-&gt;strokeColor = &quot;fe0000&quot;" expr-type="expr"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccenttick" name-type="" not="" not-type="" value="2" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;fillColor = &quot;f17c36&quot;" expr-type="expr"/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;strokeColor = &quot;f17c36&quot;" expr-type="expr"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccenttick" name-type="" not="" not-type="" value="3" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;fillColor = &quot;ffff00&quot;" expr-type="expr"/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;strokeColor = &quot;ffff00&quot;" expr-type="expr"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccenttick" name-type="" not="" not-type="" value="4" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;fillColor = &quot;01c000&quot;" expr-type="expr"/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;strokeColor = &quot;01c000&quot;" expr-type="expr"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccenttick" name-type="" not="" not-type="" value="5" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;fillColor = &quot;0000c0&quot;" expr-type="expr"/>
      <phpLine expr="$this-&gt;magicrect_control-&gt;strokeColor = &quot;0000c0&quot;" expr-type="expr"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_rgbaccenttick" name-type="" not="" not-type="" value="6" value-type="string"/>
