      <phpLine expr="$rzhaka0 = $GLOBALS['vtb_callmins']" expr-type="expr"/>
      <phpLine expr="$rzhaka = $GLOBALS['vtb_callsecs']" expr-type="expr"/>
      <setVar name="vtb_calltime" name-type="" value="" value-type="string"/>
