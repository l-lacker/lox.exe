      <openBlock/>
      <setVar name="vtb_calltime" name-type="" value="0" value-type="string"/>
      <closeBlock/>
      <appendVar asString="1" asString-type="" name="vtb_calltime" name-type="" value="rzhaka0" value-type="variable"/>
      <appendVar asString="1" asString-type="" name="vtb_calltime" name-type="" value=":" value-type="string"/>
      <ifVar method="smaller" method-type="" name="vtb_callsecs" name-type="" not="" not-type="" value="10" value-type="integer"/>
      <openBlock/>
      <appendVar asString="1" asString-type="" name="vtb_calltime" name-type="" value="0" value-type="string"/>
      <closeBlock/>
      <appendVar asString="1" asString-type="" name="vtb_calltime" name-type="" value="rzhaka" value-type="variable"/>
      <elementSetText object="callcounter" object-type="object" relative="" relative-type="" value="vtb_calltime" value-type="globalVariable"/>
      <closeBlock/>
    </method>
  
  
