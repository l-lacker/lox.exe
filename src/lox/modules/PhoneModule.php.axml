  <method name="doTimerVolumeAction">
      <phpLine expr="$volumeow = $GLOBALS['vt_volcol']/100" expr-type="expr"/>
      <phpLine expr="$this-&gt;videoPlayer-&gt;volume = $volumeow" expr-type="expr"/>
      <phpLine expr="$this-&gt;videoPlayerAlt-&gt;volume = $volumeow" expr-type="expr"/>
      <ifVar method="equals" method-type="" name="vt_volch2" name-type="" not="" not-type="" value="meow1" value-type="string"/>
      <openBlock/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="fragment7" object-type="object" x="168" x-type="float" y="144" y-type="float"/>
      <setVar name="vt_volch2" name-type="" value="meow2" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_volch2" name-type="" not="" not-type="" value="meow3" value-type="string"/>
      <openBlock/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="fragment7" object-type="object" x="232" x-type="float" y="144" y-type="float"/>
      <setVar name="vt_volch2" name-type="" value="" value-type="string"/>
      <exit/>
      <closeBlock/>
    </method>
  
  
  
  
  
  
  
  
  <method name="doVTtimerAction">
      <ifVar method="equals" method-type="" name="vt_usedvol" name-type="" not="" not-type="" value="5" value-type="string"/>
      <openBlock/>
      <setVar name="vt_usedvol" name-type="" value="4" value-type="string"/>
      <setVar name="loxstat_opened" name-type="" value="browser" value-type="string"/>
      <elementSetText object="edit" object-type="object" relative="" relative-type="" value="Загрузка..." value-type="string"/>
      <setVar name="googload" name-type="" value="https://www.google.ru/" value-type="string"/>
      <elementSetX object="appBrowser" object-type="object" relative="" relative-type="" value="224" value-type="integer"/>
      <elementSetY object="appBrowser" object-type="object" relative="" relative-type="" value="392" value-type="integer"/>
      <fadeTo continue="" continue-type="" duration="1" duration-type="integer" object="appBrowser" object-type="object" value="0" value-type="float"/>
      <elementShow object="appBrowser" object-type="object"/>
      <fadeTo continue="1" continue-type="" duration="250" duration-type="integer" object="appBrowser" object-type="object" value="1" value-type="float"/>
      <moveTo continue="" continue-type="" duration="250" duration-type="integer" object="appBrowser" object-type="object" x="224" x-type="float" y="112" y-type="float"/>
      <elementLoadContent object="mobilebrowser" object-type="object" path="googload" path-type="globalVariable" sync="" sync-type=""/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_usedvol" name-type="" not="" not-type="" value="4" value-type="string"/>
      <openBlock/>
      <setVar name="vt_usedvol" name-type="" value="3" value-type="string"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="notificationPanel" object-type="object" x="224" x-type="float" y="-192" y-type="float"/>
      <setVar name="openpanel" name-type="" value="0" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_usedvol" name-type="" not="" not-type="" value="2" value-type="string"/>
      <openBlock/>
      <setVar name="vt_usedvol" name-type="" value="3" value-type="string"/>
      <setVar name="blockpp" name-type="" value="0" value-type="string"/>
      <setVar name="openpanel" name-type="" value="0" value-type="string"/>
      <elementSetY object="notificationPanel" object-type="object" relative="" relative-type="" value="-192" value-type="integer"/>
      <displace continue="1" continue-type="" duration="250" duration-type="integer" object="notificationPanel" object-type="object" x="0" x-type="float" y="64" y-type="float"/>
      <stopMedia id="ringplayer" id-type="string"/>
      <playMedia id="ringplayer" id-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_vvpload" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="vt_vvpload" name-type="" value="" value-type="string"/>
      <elementSetX object="vovapay" object-type="object" relative="" relative-type="" value="224" value-type="integer"/>
      <elementSetY object="vovapay" object-type="object" relative="" relative-type="" value="88" value-type="integer"/>
      <elementShow object="vovapay" object-type="object"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_vpload" name-type="" not="" not-type="" value="6" value-type="string"/>
      <openBlock/>
      <setVar name="vt_vpload" name-type="" value="5" value-type="string"/>
      <elementHide object="image8" object-type="object"/>
      <elementHide object="vovapay" object-type="object"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_vpload" name-type="" not="" not-type="" value="4" value-type="string"/>
      <openBlock/>
      <setVar name="vt_vpload" name-type="" value="5" value-type="string"/>
      <setVar name="errorapi" name-type="" value="1" value-type="string"/>
      <setVar name="errorapi_title" name-type="" value="Успешная транзакция" value-type="string"/>
      <setVar name="errorapi_desc" name-type="" value="Благодарим за покупку!" value-type="string"/>
      <elementHide object="image8" object-type="object"/>
      <elementHide object="vovapay" object-type="object"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_makeblur" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="vt_makeblur" name-type="" value="" value-type="string"/>
      <setVar name="openpanel" name-type="" value="0" value-type="string"/>
      <elementSetY object="notificationPanel" object-type="object" relative="" relative-type="" value="-192" value-type="integer"/>
      <ifDirExists file="$_ENV['TEMP']" file-type="variable" not="" not-type=""/>
      <openBlock/>
      <phpLine expr="$image = $this-&gt;layout-&gt;snapshot()" expr-type="expr"/>
      <phpLine expr="$filename = $_ENV['TEMP'].'/temp.lox'" expr-type="expr"/>
      <phpLine expr="fs::ensureParent($filename)" expr-type="expr"/>
      <phpLine expr="$image-&gt;save($filename, 'png')" expr-type="expr"/>
      <elementLoadContent object="image8" object-type="object" path="filename" path-type="variable" sync="" sync-type=""/>
      <elementShow object="image8" object-type="object"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <setVar name="errorapi" name-type="" value="1" value-type="string"/>
      <setVar name="errorapi_title" name-type="" value="Макось момент?" value-type="string"/>
      <setVar name="errorapi_desc" name-type="" value="Ваша система не тянет блюрчик, поэтому жрите как есть :DDDDDD" value-type="string"/>
      <closeBlock/>
      <setVar name="vt_vpload" name-type="" value="1" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vt_newcol" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="vt_newcol" name-type="" value="" value-type="string"/>
      <setVar name="vt_collinktotal" name-type="" value="https://l-lacker.ru/app/phone/colors/at-" value-type="string"/>
      <appendVar asString="1" asString-type="" name="vt_collinktotal" name-type="" value="$GLOBALS['vt_collink']" value-type="expr"/>
      <appendVar asString="1" asString-type="" name="vt_collinktotal" name-type="" value=".png" value-type="string"/>
      <elementLoadContent object="imageAlt" object-type="object" path="vt_collinktotal" path-type="globalVariable" sync="" sync-type=""/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="headphicon" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <fadeTo continue="1" continue-type="" duration="1" duration-type="integer" object="image6" object-type="object" value="1" value-type="float"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <fadeTo continue="1" continue-type="" duration="1" duration-type="integer" object="image6" object-type="object" value="0" value-type="float"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="blockpp" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="blockpp" name-type="" value="2" value-type="string"/>
      <phpLine expr="$this-&gt;notificationPanel-&gt;dragging-&gt;enabled = false" expr-type="expr"/>
      <setVar name="openpanel" name-type="" value="1" value-type="string"/>
      <elementSetY object="notificationPanel" object-type="object" relative="" relative-type="" value="88" value-type="integer"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="blockpp" name-type="" not="" not-type="" value="0" value-type="string"/>
      <openBlock/>
      <setVar name="blockpp" name-type="" value="" value-type="string"/>
      <phpLine expr="$this-&gt;notificationPanel-&gt;dragging-&gt;enabled = true" expr-type="expr"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="lc_unlockmode" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="lc_unlockmode" name-type="" value="" value-type="string"/>
      <fadeTo continue="1" continue-type="" duration="250" duration-type="integer" object="fragment6" object-type="object" value="0" value-type="float"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="loxIcon1" object-type="object" x="240" x-type="float" y="208" y-type="float"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="loxIcon6" object-type="object" x="400" x-type="float" y="208" y-type="float"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="loxIcon3" object-type="object" x="240" x-type="float" y="304" y-type="float"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="loxIcon2" object-type="object" x="320" x-type="float" y="304" y-type="float"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="loxIcon4" object-type="object" x="400" x-type="float" y="304" y-type="float"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="rectAlt" object-type="object" x="232" x-type="float" y="296" y-type="float"/>
      <fadeTo continue="1" continue-type="" duration="150" duration-type="integer" object="loxIcon5" object-type="object" value="1" value-type="float"/>
      <fadeTo continue="1" continue-type="" duration="150" duration-type="integer" object="image3" object-type="object" value="1" value-type="float"/>
      <fadeTo continue="1" continue-type="" duration="150" duration-type="integer" object="label10" object-type="object" value="1" value-type="float"/>
      <fadeTo continue="1" continue-type="" duration="150" duration-type="integer" object="label9" object-type="object" value="1" value-type="float"/>
      <elementHide object="fragment6" object-type="object"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="lvNoPanel" name-type="" not="1" not-type="" value="1" value-type="string"/>
      <elementShow object="image" object-type="object"/>
      <else/>
      <elementHide object="image" object-type="object"/>
      <ifVar method="equals" method-type="" name="vtmode" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <elementShow object="vovatechErr1" object-type="object"/>
      <elementEnabledOn object="vovatechErr1" object-type="object"/>
      <exit/>
      <closeBlock/>
