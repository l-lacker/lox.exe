  <method name="doStatCountAction">
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="" value-type="string"/>
      <openBlock/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="other" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="loxstat_otherc" name-type="" value="1" value-type="string"/>
      <phpLine expr="$GLOBALS['loxstat_other'] = $GLOBALS['loxstat_otherc']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="loxstat_other" name-type="" value=" сек — прочее" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="settings" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="loxstat_settingsc" name-type="" value="1" value-type="string"/>
      <phpLine expr="$GLOBALS['loxstat_settings'] = $GLOBALS['loxstat_settingsc']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="loxstat_settings" name-type="" value=" сек" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="loxvideos" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="loxstat_loxvideosc" name-type="" value="1" value-type="string"/>
      <phpLine expr="$GLOBALS['loxstat_loxvideos'] = $GLOBALS['loxstat_loxvideosc']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="loxstat_loxvideos" name-type="" value=" сек" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="gallery" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="loxstat_galleryc" name-type="" value="1" value-type="string"/>
      <phpLine expr="$GLOBALS['loxstat_gallery'] = $GLOBALS['loxstat_galleryc']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="loxstat_gallery" name-type="" value=" сек" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="browser" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="loxstat_browserc" name-type="" value="1" value-type="string"/>
      <phpLine expr="$GLOBALS['loxstat_browser'] = $GLOBALS['loxstat_browserc']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="loxstat_browser" name-type="" value=" сек" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="calc" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="loxstat_calcc" name-type="" value="1" value-type="string"/>
      <phpLine expr="$GLOBALS['loxstat_calc'] = $GLOBALS['loxstat_calcc']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="loxstat_calc" name-type="" value=" сек" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="loxstat_opened" name-type="" not="" not-type="" value="lucky" value-type="string"/>
      <openBlock/>
      <appendVar asString="" asString-type="" name="loxstat_luckyc" name-type="" value="1" value-type="string"/>
      <phpLine expr="$GLOBALS['loxstat_lucky'] = $GLOBALS['loxstat_luckyc']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="loxstat_lucky" name-type="" value=" сек" value-type="string"/>
      <closeBlock/>
    </method>
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
