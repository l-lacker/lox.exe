  <method name="doButton8MouseDownLeft">
      <ifVar method="equals" method-type="" name="vtb_opened" name-type="" not="" not-type="" value="home" value-type="string"/>
      <openBlock/>
      <setVar name="vtb_arrow" name-type="" value="cipherblock" value-type="string"/>
      <setVar name="vtb_opened" name-type="" value="cipherblock" value-type="string"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="vtb_opened" name-type="" not="" not-type="" value="cipherblock" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;dtmfsound-&gt;open('res://.data/audio/DTMF-1.mp3')" expr-type="expr"/>
      <phpLine expr="$this-&gt;dtmfsound-&gt;play()" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="vtb_cipherblock" name-type="" value="1" value-type="string"/>
      <closeBlock/>
    </method>
