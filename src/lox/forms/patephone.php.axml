      <appendVar asString="1" asString-type="" name="vtb_cipherblock" name-type="" value="*" value-type="string"/>
      <closeBlock/>
      <sleep sync="" sync-type="" value="1000" value-type="integer"/>
      <ifVar method="equals" method-type="" name="vtb_availstar" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="vtb_cipherblock" name-type="" value="+" value-type="string"/>
      <setVar name="vtb_availstar" name-type="" value="" value-type="string"/>
      <closeBlock/>
    </method>
