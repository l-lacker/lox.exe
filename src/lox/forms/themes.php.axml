  <method name="doButton3Action">
      <ifVar method="equals" method-type="" name="cursor_shadow" name-type="" not="1" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <setVar name="cursor_shadow" name-type="" value="1" value-type="string"/>
      <behaviourEnable behaviour="behaviour\custom\DropShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;wincursor" object-type="object"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="отключить" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <setVar name="cursor_shadow" name-type="" value="0" value-type="string"/>
      <behaviourDisable behaviour="behaviour\custom\DropShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;wincursor" object-type="object"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="включить" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <closeBlock/>
    </method>
