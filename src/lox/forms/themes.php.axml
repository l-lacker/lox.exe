  <method name="doButton13Action">
      <ifVar method="equals" method-type="" name="lox-freecats" name-type="" not="1" not-type="" value="1" value-type="integer"/>
      <openBlock/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Разблокируйте в l-lacker Lucky" value-type="string"/>
      <stopMedia id="loxerr" id-type="string"/>
      <openMedia autoplay="1" autoplay-type="flag" id="loxerr" id-type="string" source="res://.data/audio/lox-error.mp3" source-type="string"/>
      <sleep sync="" sync-type="" value="2000" value-type="integer"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="ОБОИ С БЕСПЛАТНЫМИ КОТЯТАМИ" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <elementLoadContent object="form('MainForm')-&gt;wallpaper" object-type="object" path="res://.data/img/bestwallever.jpg" path-type="string" sync="" sync-type=""/>
      <closeBlock/>
    </method>
  <method name="doButton5Action">
      <ifVar method="equals" method-type="" name="wallmode" name-type="" not="" not-type="" value="0" value-type="string"/>
      <openBlock/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="включить" value-type="string"/>
      <elementHide object="form('MainForm')-&gt;wallpaper" object-type="object"/>
      <setVar name="wallmode" name-type="" value="1" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="wallmode" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="отключить" value-type="string"/>
      <elementShow object="form('MainForm')-&gt;wallpaper" object-type="object"/>
      <setVar name="wallmode" name-type="" value="0" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <closeBlock/>
    </method>
  
