    <method name="doCNLAct">
      <ifVar method="equals" method-type="" name="video_now" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <elementHide object="contentnotloaded" object-type="object"/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <phpLine expr="$this-&gt;videoPlayer-&gt;pause()" expr-type="expr"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="mediaView" object-type="object" x="0" x-type="float" y="0" y-type="float"/>
      <moveTo continue="" continue-type="" duration="250" duration-type="integer" object="mediaViewAlt" object-type="object" x="0" x-type="float" y="280" y-type="float"/>
      <elementSetY object="mediaView" object-type="object" relative="" relative-type="" value="568" value-type="integer"/>
      <phpLine expr="$this-&gt;videoPlayer-&gt;stop()" expr-type="expr"/>
      <phpLine expr="$randurl = rand(1,10000)" expr-type="expr"/>
      <phpLine expr="$this-&gt;videoPlayer-&gt;open('https://l-lacker.ru/app/random.php?hash='.$randurl.'0')" expr-type="expr"/>
      <phpLine expr="$this-&gt;videoPlayerAlt-&gt;play()" expr-type="expr"/>
      <setVar name="contentaccess" name-type="" value="2" value-type="string"/>
      <setVar name="video_now" name-type="" value="2" value-type="string"/>
      <sleep sync="" sync-type="" value="5000" value-type="integer"/>
      <setVar name="contentaccess" name-type="" value="0" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="video_now" name-type="" not="" not-type="" value="2" value-type="string"/>
      <openBlock/>
      <elementHide object="contentnotloaded" object-type="object"/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <phpLine expr="$this-&gt;videoPlayerAlt-&gt;pause()" expr-type="expr"/>
      <moveTo continue="1" continue-type="" duration="250" duration-type="integer" object="mediaViewAlt" object-type="object" x="0" x-type="float" y="0" y-type="float"/>
      <moveTo continue="" continue-type="" duration="250" duration-type="integer" object="mediaView" object-type="object" x="0" x-type="float" y="280" y-type="float"/>
      <elementSetY object="mediaViewAlt" object-type="object" relative="" relative-type="" value="568" value-type="integer"/>
      <phpLine expr="$this-&gt;videoPlayerAlt-&gt;stop()" expr-type="expr"/>
      <phpLine expr="$randurl = rand(1,10000)" expr-type="expr"/>
      <phpLine expr="$this-&gt;videoPlayerAlt-&gt;open('https://l-lacker.ru/app/random.php?hash='.$randurl.'0')" expr-type="expr"/>
      <phpLine expr="$this-&gt;videoPlayer-&gt;play()" expr-type="expr"/>
      <setVar name="contentaccess" name-type="" value="2" value-type="string"/>
      <setVar name="video_now" name-type="" value="1" value-type="string"/>
      <sleep sync="" sync-type="" value="5000" value-type="integer"/>
      <setVar name="contentaccess" name-type="" value="0" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <closeBlock/>
    </method>
    <method name="doCNLMouseDownL">
