  <method name="doButton7Action">
      <setVar name="masic_load_link" name-type="" value="https://l-lacker.ru/app/masic/p/random.php?alb=3" value-type="string"/>
      <setVar name="masic_helper" name-type="" value="1" value-type="string"/>
      <elementSetText object="label9" object-type="object" relative="" relative-type="" value="rand(1,99999)" value-type="expr"/>
      <elementSetText object="label6" object-type="object" relative="" relative-type="" value="Загрузка..." value-type="string"/>
      <phpLine expr="$this-&gt;masicplayer-&gt;open($GLOBALS['masic_load_link'])" expr-type="expr"/>
      <elementHide object="button10" object-type="object"/>
