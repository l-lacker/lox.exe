    </method>
  <method name="doButton8Action">
      <phpLine expr="$this-&gt;timer-&gt;stop()" expr-type="expr"/>
      <phpLine expr="$this-&gt;lnfr-&gt;stop()" expr-type="expr"/>
      <phpLine expr="$this-&gt;masicplayer-&gt;stop()" expr-type="expr"/>
      <phpLine expr="$this-&gt;masicplayer2-&gt;stop()" expr-type="expr"/>
      <setVar name="masic_helper" name-type="" value="" value-type="string"/>
      <setVar name="masic_megazhopa" name-type="" value="" value-type="string"/>
      <appendVar asString="" asString-type="" name="masic_stopcount" name-type="" value="1" value-type="string"/>
      <elementHide object="panel5" object-type="object"/>
      <elementSetX object="panelAlt" object-type="object" relative="" relative-type="" value="544" value-type="integer"/>
      <behaviourDisable behaviour="behaviour\custom\RotateAnimationBehaviour" behaviour-type="string" object="image7" object-type="object"/>
      <elementHide object="button11" object-type="object"/>
      <elementShow object="button9" object-type="object"/>
      <setVar name="headphicon" name-type="" value="" value-type="string"/>
    </method>
  <method name="doButton9Action">
      <appendVar asString="" asString-type="" name="masic_stopcount" name-type="" value="1" value-type="string"/>
      <ifVar method="equals" method-type="" name="masic_nowplaying" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;timer-&gt;stop()" expr-type="expr"/>
      <setVar name="masic_helper" name-type="" value="" value-type="string"/>
      <phpLine expr="$this-&gt;masicplayer-&gt;pause()" expr-type="expr"/>
      <elementHide object="button9" object-type="object"/>
      <elementShow object="button11" object-type="object"/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="masic_nowplaying" name-type="" not="" not-type="" value="2" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;timer-&gt;stop()" expr-type="expr"/>
      <setVar name="masic_helper" name-type="" value="" value-type="string"/>
      <phpLine expr="$this-&gt;masicplayer2-&gt;pause()" expr-type="expr"/>
      <elementHide object="button9" object-type="object"/>
      <elementShow object="button11" object-type="object"/>
      <closeBlock/>
    </method>
  
  <method name="doButton20_offAction">
      <ifVar method="equals" method-type="" name="vt_collink" name-type="" not="" not-type="" value="greyslim" value-type="string"/>
      <openBlock/>
      <setVar name="errorapi" name-type="" value="1" value-type="string"/>
      <setVar name="errorapi_title" name-type="" value="Телефон слишком тонкий" value-type="string"/>
      <setVar name="errorapi_desc" name-type="" value="В ваш супер-тонкий телефон не влез фонарик. Поменяйте его через &quot;Магазин&quot;." value-type="string"/>
      <exit/>
      <closeBlock/>
      <elementShow object="button20_on" object-type="object"/>
      <elementShow object="form('MainForm')-&gt;image_torch" object-type="object"/>
      <setVar name="vttorch" name-type="" value="enabled" value-type="string"/>
    </method>
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
    
    
    
  
  
  
  
  <method name="doButton13Action">
      <elementHide object="panel6" object-type="object"/>
      <ifVar method="equals" method-type="" name="openpanel" name-type="" not="" not-type="" value="0" value-type="string"/>
      <openBlock/>
      <setVar name="vt_usedvol" name-type="" value="4" value-type="string"/>
      <closeBlock/>
    </method>
  <method name="doButton12Action">
      <elementHide object="panel6" object-type="object"/>
      <setVar name="vt_usedvol" name-type="" value="5" value-type="string"/>
    </method>
  <method name="doButton23Action">
      <ifVar method="equals" method-type="" name="lox_totallight" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="errorapi" name-type="" value="1" value-type="string"/>
      <setVar name="errorapi_title" name-type="" value="Нет нужды в aloPay" value-type="string"/>
      <setVar name="errorapi_desc" name-type="" value="Вы находитесь в Light-режиме, и здесь для Вас магазин всегда открыт!" value-type="string"/>
      <exit/>
      <closeBlock/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <setVar name="vt_vvpload" name-type="" value="1" value-type="string"/>
      <setVar name="vt_makeblur" name-type="" value="1" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <ifVar method="equals" method-type="" name="vt_vpload" name-type="" not="1" not-type="" value="2" value-type="string"/>
      <openBlock/>
      <setVar name="vt_vpload" name-type="" value="1" value-type="string"/>
      <closeBlock/>
      <setVar name="errorapi" name-type="" value="1" value-type="string"/>
      <setVar name="errorapi_title" name-type="" value="Извини" value-type="string"/>
      <setVar name="errorapi_desc" name-type="" value="Локс крин залочен" value-type="string"/>
    </method>
  </class>
</root>
