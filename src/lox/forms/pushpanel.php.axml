      <sleep sync="" sync-type="" value="2000" value-type="integer"/>
      <behaviourEnable behaviour="behaviour\custom\RotateAnimationBehaviour" behaviour-type="string" object="image7" object-type="object"/>
      <elementShow object="button10" object-type="object"/>
      <elementSetText object="label6" object-type="object" relative="" relative-type="" value="Используйте панель уведомлений для управления треками" value-type="string"/>
      <phpLine expr="$this-&gt;timer-&gt;start()" expr-type="expr"/>
      <elementShow object="panel5" object-type="object"/>
      <setVar name="headphicon" name-type="" value="1" value-type="string"/>
    </method>
