      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Куплено" value-type="string"/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <phpLine expr="$store_prikol = $GLOBALS['a'].' ₽'" expr-type="expr"/>
