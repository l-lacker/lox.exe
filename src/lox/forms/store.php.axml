  <method name="doButton16Action">
      <ifVar method="equals" method-type="" name="lox-unlimbillets" name-type="" not="1" not-type="" value="1" value-type="integer"/>
      <openBlock/>
      <ifVar method="smaller" method-type="" name="a" name-type="" not="" not-type="" value="25" value-type="integer"/>
      <openBlock/>
      <elementSetText object="form('MainForm')-&gt;PODSKAZKA" object-type="object" relative="" relative-type="" value="Невозможно совершить покупку! У Вас не хватает средств." value-type="string"/>
      <stopMedia id="xpnotiplayer" id-type="string"/>
      <openMedia autoplay="1" autoplay-type="flag" id="xpnotiplayer" id-type="string" source="res://.data/audio/lox-error.mp3" source-type="string"/>
      <exit/>
      <closeBlock/>
      <appendVar asString="" asString-type="" name="a" name-type="" value="-25" value-type="string"/>
      <phpLine expr="$store_prikol = $GLOBALS['a'].' ₽'" expr-type="expr"/>
      <elementSetText object="form('MainForm')-&gt;balance_store" object-type="object" relative="" relative-type="" value="store_prikol" value-type="variable"/>
      <stopMedia id="xpnotiplayer" id-type="string"/>
      <openMedia autoplay="1" autoplay-type="flag" id="xpnotiplayer" id-type="string" source="res://.data/audio/lox-buy.mp3" source-type="string"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <stopMedia id="xpnotiplayer2" id-type="string"/>
      <openMedia autoplay="1" autoplay-type="flag" id="xpnotiplayer2" id-type="string" source="res://.data/audio/lox-secret-theme-win.mp3" source-type="string"/>
      <closeBlock/>
      <elementHide object="panel3" object-type="object"/>
    </method>
  
  
  
  
  
  
  
  
  
  
  
  
  
