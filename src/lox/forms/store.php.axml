      <elementShow object="form('MainForm')-&gt;label37" object-type="object"/>
      <phpLine expr="$timergovn = Timer::every(10000, function () { $GLOBALS['a'] += '1'" expr-type="expr"/>
      <behaviourEnable behaviour="behaviour\custom\DropShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <behaviourEnable behaviour="behaviour\custom\InnerShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <sleep sync="" sync-type="" value="50" value-type="integer"/>
      <behaviourDisable behaviour="behaviour\custom\DropShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <behaviourDisable behaviour="behaviour\custom\InnerShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <sleep sync="" sync-type="" value="50" value-type="integer"/>
      <behaviourEnable behaviour="behaviour\custom\DropShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <behaviourEnable behaviour="behaviour\custom\InnerShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <sleep sync="" sync-type="" value="50" value-type="integer"/>
      <behaviourDisable behaviour="behaviour\custom\DropShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <behaviourDisable behaviour="behaviour\custom\InnerShadowEffectBehaviour" behaviour-type="string" object="form('MainForm')-&gt;tereb1" object-type="object"/>
      <phpLine expr="})" expr-type="expr"/>
