  <method name="doButton3Action">
      <phpLine expr="$this-&gt;clickScript-&gt;callAsync()" expr-type="expr"/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <fadeTo continue="1" continue-type="" duration="50" duration-type="integer" object="~sender" object-type="object" value="0" value-type="float"/>
