      <fadeTo continue="" continue-type="" duration="10" duration-type="integer" object="label3" object-type="object" value="0" value-type="float"/>
      <elementShow object="label3" object-type="object"/>
      <fadeTo continue="" continue-type="" duration="1000" duration-type="integer" object="label3" object-type="object" value="1" value-type="float"/>
      <sleep sync="" sync-type="" value="3000" value-type="integer"/>
      <fadeTo continue="" continue-type="" duration="10" duration-type="integer" object="button4" object-type="object" value="0" value-type="float"/>
      <elementShow object="button4" object-type="object"/>
