  <method name="doButtonAction">
      <phpLine expr="$this-&gt;clickScript-&gt;callAsync()" expr-type="expr"/>
      <elementHide object="label3" object-type="object"/>
      <elementHide object="button4" object-type="object"/>
      <elementHide object="button3" object-type="object"/>
      <elementSetX object="panel3" object-type="object" relative="" relative-type="" value="0" value-type="integer"/>
      <elementSetY object="panel3" object-type="object" relative="" relative-type="" value="0" value-type="integer"/>
      <elementHide object="panel" object-type="object"/>
      <elementShow object="panel3" object-type="object"/>
      <sleep sync="" sync-type="" value="7000" value-type="integer"/>
      <elementEnabledOn object="button7" object-type="object"/>
    </method>
  
  <method name="doLinkAltAction">
      <phpLine expr="$this-&gt;clickScript-&gt;callAsync()" expr-type="expr"/>
