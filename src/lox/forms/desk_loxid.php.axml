  <method name="doEditKeyUpCtrlV">
      <setVar name="tglinktest" name-type="" value="$e-&gt;sender-&gt;text" value-type="expr"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="" value-type="string"/>
      <phpLine expr="$GLOBALS['tglinktest'] = str_replace('httpstme', '', $GLOBALS['tglinktest'])" expr-type="expr"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="tglinktest" value-type="globalVariable"/>
    </method>
