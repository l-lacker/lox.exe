  <method name="doButton7Action">
      <elementEnabledOff object="~sender" object-type="object"/>
      <setVar name="luckycomms" name-type="" value="0" value-type="string"/>
      <setVar name="newcommmake" name-type="" value="$this-&gt;edit_name-&gt;text" value-type="expr"/>
      <appendVar asString="1" asString-type="" name="newcommmake" name-type="" value=": " value-type="string"/>
      <appendVar asString="1" asString-type="" name="newcommmake" name-type="" value="$this-&gt;edit_comm-&gt;text" value-type="expr"/>
      <elementSetText object="labelAlt" object-type="object" relative="" relative-type="" value="newcommmake" value-type="globalVariable"/>
      <elementHide object="OVERALL_panel2" object-type="object"/>
      <behaviourDisable behaviour="behaviour\custom\GaussianBlurEffectBehaviour" behaviour-type="string" object="panelMainBG" object-type="object"/>
      <behaviourDisable behaviour="behaviour\custom\GaussianBlurEffectBehaviour" behaviour-type="string" object="panelWelcome" object-type="object"/>
      <behaviourDisable behaviour="behaviour\custom\GaussianBlurEffectBehaviour" behaviour-type="string" object="panelAlt" object-type="object"/>
      <displace continue="1" continue-type="" duration="250" duration-type="integer" object="panelMainBG" object-type="object" x="2" x-type="float" y="-4" y-type="float"/>
      <ifVar method="equals" method-type="" name="luckyprikol" name-type="" not="" not-type="" value="" value-type="string"/>
      <openBlock/>
      <displace continue="1" continue-type="" duration="250" duration-type="integer" object="panelWelcome" object-type="object" x="-8" x-type="float" y="-2" y-type="float"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <displace continue="1" continue-type="" duration="250" duration-type="integer" object="panelWelcome" object-type="object" x="0" x-type="float" y="-2" y-type="float"/>
      <closeBlock/>
      <displace continue="1" continue-type="" duration="250" duration-type="integer" object="panel" object-type="object" x="0" x-type="float" y="-56" y-type="float"/>
      <fadeTo continue="" continue-type="" duration="250" duration-type="integer" object="OVERALL_panel" object-type="object" value="0" value-type="float"/>
      <stopMedia id="commpop" id-type="string"/>
      <openMedia autoplay="1" autoplay-type="flag" id="commpop" id-type="string" source="res://.data/audio/pop.mp3" source-type="string"/>
      <elementHide object="OVERALL_panel" object-type="object"/>
      <sleep sync="" sync-type="" value="2000" value-type="integer"/>
      <setVar name="luckycomms" name-type="" value="1" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
    </method>
    
    
  
