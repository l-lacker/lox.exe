  <method name="doImageAltClickLeft">
      <ifVar method="equals" method-type="" name="luckyprikol" name-type="" not="" not-type="" value="" value-type="string"/>
      <openBlock/>
      <elementLoadContent object="~sender" object-type="object" path="res://.data/img/llucky-overlay2.png" path-type="string" sync="" sync-type=""/>
      <setVar name="luckyprikol" name-type="" value="2" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="luckyprikol" name-type="" not="" not-type="" value="2" value-type="string"/>
      <openBlock/>
      <elementLoadContent object="~sender" object-type="object" path="res://.data/img/llucky-overlay3.png" path-type="string" sync="" sync-type=""/>
      <setVar name="luckyprikol" name-type="" value="3" value-type="string"/>
      <exit/>
      <closeBlock/>
      <ifVar method="equals" method-type="" name="luckyprikol" name-type="" not="" not-type="" value="3" value-type="string"/>
      <openBlock/>
      <elementEnabledOff object="OVERALL_button" object-type="object"/>
      <phpLine expr="$this-&gt;luckyHelper-&gt;start()" expr-type="expr"/>
      <phpLine expr="$this-&gt;comments-&gt;start()" expr-type="expr"/>
      <phpLine expr="$this-&gt;luckym1-&gt;start()" expr-type="expr"/>
      <elementLoadContent object="~sender" object-type="object" path="res://.data/img/llucky-overlay4.png" path-type="string" sync="" sync-type=""/>
      <setVar name="llucky_sbrosfreq" name-type="" value="0" value-type="string"/>
      <setVar name="luckyprikol" name-type="" value="no" value-type="string"/>
      <elementHide object="label" object-type="object"/>
      <elementShow object="progressIndicator" object-type="object"/>
      <openUrlMedia autoplay="" autoplay-type="flag" id="luckyp-start" id-type="string" source="https://l-lacker.ru/app/lucky/game-start.mp3" source-type="string"/>
      <sleep sync="" sync-type="" value="1000" value-type="integer"/>
      <elementLoadContent object="tempimg1" object-type="object" path="https://l-lacker.ru/app/lucky/llucky-screen1.png" path-type="string" sync="" sync-type=""/>
      <elementLoadContent object="tempimg2" object-type="object" path="https://l-lacker.ru/app/lucky/llucky-screen2.png" path-type="string" sync="" sync-type=""/>
      <elementLoadContent object="tempimg3" object-type="object" path="https://l-lacker.ru/app/lucky/llucky-screen3.png" path-type="string" sync="" sync-type=""/>
      <elementLoadContent object="tempimg4" object-type="object" path="https://l-lacker.ru/app/lucky/llucky-screen4.png" path-type="string" sync="" sync-type=""/>
      <elementLoadContent object="tempimg5" object-type="object" path="https://l-lacker.ru/app/lucky/llucky-screen5.png" path-type="string" sync="" sync-type=""/>
      <phpLine expr="$this-&gt;image3-&gt;image = $this-&gt;tempimg1-&gt;image" expr-type="expr"/>
      <elementSetX object="panelAlt" object-type="object" relative="" relative-type="" value="0" value-type="integer"/>
      <elementSetX object="panel" object-type="object" relative="" relative-type="" value="0" value-type="integer"/>
      <elementSetY object="panel" object-type="object" relative="" relative-type="" value="224" value-type="integer"/>
      <elementEnabledOn object="OVERALL_button" object-type="object"/>
      <setVar name="luckycomms" name-type="" value="1" value-type="string"/>
      <setVar name="luckymode" name-type="" value="fiveslides" value-type="string"/>
      <playMedia id="luckyp-start" id-type="string"/>
      <phpLine expr="$this-&gt;playerHelper-&gt;open('https://l-lacker.ru/app/lucky/llucky-welcome-ffmpeg.mp4')" expr-type="expr"/>
      <elementLoadContent object="~sender" object-type="object" path="res://.data/img/llucky-overlay5.png" path-type="string" sync="" sync-type=""/>
      <sleep sync="" sync-type="" value="10000" value-type="integer"/>
      <elementShow object="button6" object-type="object"/>
      <phpLine expr="$this-&gt;playerTicks-&gt;open('https://l-lacker.ru/app/lucky/llucky-ticks.mp3')" expr-type="expr"/>
      <exit/>
      <closeBlock/>
    </method>
  
  <method name="doButton_answ1Action">
      <stopMedia id="luckyselector" id-type="string"/>
      <openMedia autoplay="1" autoplay-type="flag" id="luckyselector" id-type="string" source="res://.data/audio/lucky-select.mp3" source-type="string"/>
      <elementHide object="~sender" object-type="object"/>
      <elementEnabledOff object="button_answ2" object-type="object"/>
      <elementEnabledOff object="button_answ3" object-type="object"/>
      <setVar name="lucky_selectedansw" name-type="" value="1" value-type="string"/>
      <phpLine expr="if ($GLOBALS['luckytruanswer'] == &quot;4&quot;) //" expr-type="expr"/>
      <openBlock/>
      <setVar name="lucky_kostyl" name-type="" value="true" value-type="string"/>
      <setVar name="lucky_kostyl2" name-type="" value="true" value-type="string"/>
      <exit/>
      <closeBlock/>
      <phpLine expr="if ($GLOBALS['luckytruanswer'] == &quot;1&quot;) //" expr-type="expr"/>
      <openBlock/>
      <setVar name="lucky_kostyl" name-type="" value="true" value-type="string"/>
      <exit/>
      <closeBlock/>
      <phpLine expr="if ($GLOBALS['luckytruanswer'] != &quot;1&quot;) //" expr-type="expr"/>
