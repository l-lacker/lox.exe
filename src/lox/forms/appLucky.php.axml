  <method name="doButton6Action">
      <ifVar method="equals" method-type="" name="llucky_boost1" name-type="" not="1" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <elementHide object="~sender" object-type="object"/>
      <setVar name="luckymode" name-type="" value="ingameprepare" value-type="string"/>
      <phpLine expr="$this-&gt;playerMain-&gt;open('https://l-lacker.ru/app/lucky/game-main.mp3')" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMainPitch-&gt;open('https://l-lacker.ru/app/lucky/game-main-pitch.mp3')" expr-type="expr"/>
      <phpLine expr="$this-&gt;ANSWER1_label-&gt;mouseTransparent = true" expr-type="expr"/>
      <phpLine expr="$this-&gt;ANSWER2_label-&gt;mouseTransparent = true" expr-type="expr"/>
      <phpLine expr="$this-&gt;ANSWER3_label-&gt;mouseTransparent = true" expr-type="expr"/>
      <stopMedia id="luckyp-start" id-type="string"/>
      <elementShow object="mediaView" object-type="object"/>
      <elementSetX object="mediaView" object-type="object" relative="" relative-type="" value="-16" value-type="integer"/>
      <phpLine expr="$this-&gt;playerHelper-&gt;play()" expr-type="expr"/>
      <sleep sync="" sync-type="" value="18000" value-type="integer"/>
      <setVar name="luckymode" name-type="" value="ingame" value-type="string"/>
      <elementShow object="LABEL_count" object-type="object"/>
      <elementShow object="LABEL_truequests" object-type="object"/>
      <setVar name="luckyfullcount" name-type="" value="Отвечено на 0 вопросов из " value-type="string"/>
      <phpLine expr="$luckycount = $GLOBALS['luckycount2']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="luckyfullcount" name-type="" value="luckycount" value-type="variable"/>
      <elementSetText object="LABEL_truequests" object-type="object" relative="" relative-type="" value="luckyfullcount" value-type="globalVariable"/>
      <elementHide object="mediaView" object-type="object"/>
      <phpLine expr="$this-&gt;playerMain-&gt;play()" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMainPitch-&gt;play()" expr-type="expr"/>
      <exit/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <elementHide object="~sender" object-type="object"/>
      <setVar name="luckymode" name-type="" value="ingameprepare" value-type="string"/>
      <phpLine expr="$this-&gt;playerMain-&gt;open('https://l-lacker.ru/app/lucky/game-main.mp3')" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMainPitch-&gt;open('https://l-lacker.ru/app/lucky/game-main-pitch.mp3')" expr-type="expr"/>
      <phpLine expr="$this-&gt;ANSWER1_label-&gt;mouseTransparent = true" expr-type="expr"/>
      <phpLine expr="$this-&gt;ANSWER2_label-&gt;mouseTransparent = true" expr-type="expr"/>
      <phpLine expr="$this-&gt;ANSWER3_label-&gt;mouseTransparent = true" expr-type="expr"/>
      <stopMedia id="luckyp-start" id-type="string"/>
      <sleep sync="" sync-type="" value="3000" value-type="integer"/>
      <setVar name="luckymode" name-type="" value="ingame" value-type="string"/>
      <elementShow object="LABEL_count" object-type="object"/>
      <elementShow object="LABEL_truequests" object-type="object"/>
      <setVar name="luckyfullcount" name-type="" value="Отвечено на 0 вопросов из " value-type="string"/>
      <phpLine expr="$luckycount = $GLOBALS['luckycount2']" expr-type="expr"/>
      <appendVar asString="1" asString-type="" name="luckyfullcount" name-type="" value="luckycount" value-type="variable"/>
      <elementSetText object="LABEL_truequests" object-type="object" relative="" relative-type="" value="luckyfullcount" value-type="globalVariable"/>
      <elementHide object="mediaView" object-type="object"/>
      <phpLine expr="$this-&gt;playerMain-&gt;play()" expr-type="expr"/>
      <phpLine expr="$this-&gt;playerMainPitch-&gt;play()" expr-type="expr"/>
      <exit/>
      <closeBlock/>
    </method>
  
  
