  <method name="doButtonAction">
      <elementEnabledOff object="~sender" object-type="object"/>
      <ifVar method="smaller" method-type="" name="worktimer" name-type="" not="" not-type="" value="5" value-type="integer"/>
      <openBlock/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Вы слишком мало работали в lox.exe и кэш не накопился" value-type="string"/>
      <sleep sync="" sync-type="" value="4000" value-type="integer"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Поработайте хотя бы 5 минут для активации очистки" value-type="string"/>
      <sleep sync="" sync-type="" value="4000" value-type="integer"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Очистить кэш lox.exe для снижения потребления ОЗУ" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <closeBlock/>
      <ifVar method="smaller" method-type="" name="cachetimer" name-type="" not="" not-type="" value="5" value-type="integer"/>
      <openBlock/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Вы слишком недавно чистили кэш, функция недоступна" value-type="string"/>
      <sleep sync="" sync-type="" value="4000" value-type="integer"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Очистить кэш lox.exe для снижения потребления ОЗУ" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <closeBlock/>
      <ifVar method="greater" method-type="" name="worktimer" name-type="" not="" not-type="" value="4" value-type="integer"/>
      <openBlock/>
      <setVar name="cachetimer" name-type="" value="0" value-type="integer"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Очистка кэша..." value-type="string"/>
      <phpLine expr="System::gc()" expr-type="expr"/>
      <sleep sync="" sync-type="" value="rand(2000,4000)" value-type="expr"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Теперь памяти стало свободно больше!" value-type="string"/>
      <sleep sync="" sync-type="" value="1000" value-type="integer"/>
      <elementSetText object="~sender" object-type="object" relative="" relative-type="" value="Очистить кэш lox.exe для снижения потребления ОЗУ" value-type="string"/>
      <elementEnabledOn object="~sender" object-type="object"/>
      <exit/>
      <closeBlock/>
    </method>
  <method name="doShow">
      <phpLine expr="$this-&gt;xp_loadscr-&gt;toFront()" expr-type="expr"/>
      <phpLine expr="$this-&gt;whiteonlyfg-&gt;toFront()" expr-type="expr"/>
      <phpLine expr="$this-&gt;onStart-&gt;start()" expr-type="expr"/>
    </method>
  <method name="doFsIgnoreAction">
      <elementEnabledOff object="fsEnable" object-type="object"/>
      <elementEnabledOff object="fsIgnore" object-type="object"/>
      <ifVar method="equals" method-type="" name="lox_totallight" name-type="" not="1" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <phpLine expr="$this-&gt;timer-&gt;start()" expr-type="expr"/>
      <phpLine expr="$this-&gt;httpChecker-&gt;start()" expr-type="expr"/>
      <phpLine expr="$this-&gt;internetCheck-&gt;start()" expr-type="expr"/>
      <phpLine expr="$this-&gt;storeBalSync-&gt;start()" expr-type="expr"/>
      <elementDestroy object="atph_run" object-type="object"/>
      <phpLine expr="$formTitle = &quot;lox\\forms\\phone&quot;" expr-type="expr"/>
      <phpLine expr="$form = new $formTitle" expr-type="expr"/>
      <phpLine expr="$form-&gt;showInFragment($this-&gt;phoneForm)" expr-type="expr"/>
      <elementDestroy object="pateph_run" object-type="object"/>
      <phpLine expr="$formTitle = &quot;lox\\forms\\patephone&quot;" expr-type="expr"/>
      <phpLine expr="$form = new $formTitle" expr-type="expr"/>
      <phpLine expr="$form-&gt;showInFragment($this-&gt;fragment16)" expr-type="expr"/>
      <phpLine expr="$formTitle = &quot;lox\\forms\\intercard&quot;" expr-type="expr"/>
      <phpLine expr="$form = new $formTitle" expr-type="expr"/>
      <phpLine expr="$form-&gt;showInFragment($this-&gt;fragment12)" expr-type="expr"/>
      <elementDestroy object="izol_run" object-type="object"/>
      <phpLine expr="$formTitle = &quot;lox\\forms\\izolyator&quot;" expr-type="expr"/>
      <phpLine expr="$form = new $formTitle" expr-type="expr"/>
      <phpLine expr="$form-&gt;showInFragment($this-&gt;fragment7)" expr-type="expr"/>
      <phpLine expr="$formTitle = &quot;lox\\forms\\screensaver&quot;" expr-type="expr"/>
      <phpLine expr="$form = new $formTitle" expr-type="expr"/>
      <phpLine expr="$form-&gt;showInFragment($this-&gt;screensaver)" expr-type="expr"/>
      <elementDestroy object="kur_run" object-type="object"/>
      <phpLine expr="$formTitle = &quot;lox\\forms\\kuranir&quot;" expr-type="expr"/>
      <phpLine expr="$form = new $formTitle" expr-type="expr"/>
      <phpLine expr="$form-&gt;showInFragment($this-&gt;fragment8)" expr-type="expr"/>
      <elementDestroy object="mypc_run" object-type="object"/>
      <phpLine expr="$formTitle = &quot;lox\\forms\\my_system&quot;" expr-type="expr"/>
      <phpLine expr="$form = new $formTitle" expr-type="expr"/>
      <phpLine expr="$form-&gt;showInFragment($this-&gt;fragment4)" expr-type="expr"/>
      <closeBlock/>
      <else/>
      <openBlock/>
      <phpLine expr="$this-&gt;internetCheck-&gt;interval = 60000" expr-type="expr"/>
      <phpLine expr="$this-&gt;internetCheck-&gt;start()" expr-type="expr"/>
      <elementDestroy object="screensaver" object-type="object"/>
      <closeBlock/>
      <fadeTo continue="1" continue-type="" duration="200" duration-type="integer" object="fragment10" object-type="object" value="0" value-type="float"/>
      <fadeTo continue="1" continue-type="" duration="200" duration-type="integer" object="fsEnable" object-type="object" value="0" value-type="float"/>
      <fadeTo continue="" continue-type="" duration="200" duration-type="integer" object="fsIgnore" object-type="object" value="0" value-type="float"/>
      <phpLine expr="$screen = UXScreen::getPrimary()" expr-type="expr"/>
      <phpLine expr="$width  = $screen-&gt;bounds['width']" expr-type="expr"/>
      <phpLine expr="$height = $screen-&gt;bounds['height']" expr-type="expr"/>
      <setVar name="width1" name-type="" value="width" value-type="variable"/>
      <setVar name="height1" name-type="" value="height" value-type="variable"/>
      <ifVar method="smaller" method-type="" name="height1" name-type="" not="" not-type="" value="800" value-type="integer"/>
      <openBlock/>
      <phpLine expr="$this-&gt;minHeight = 680" expr-type="expr"/>
      <phpLine expr="$this-&gt;maxHeight = 680" expr-type="expr"/>
      <closeBlock/>
      <elementDestroy object="fragment10" object-type="object"/>
      <elementDestroy object="fsEnable" object-type="object"/>
      <elementDestroy object="fsIgnore" object-type="object"/>
    </method>
  </class>
</root>
