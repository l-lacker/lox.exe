  <method name="doKeyDownCtrlM">
      <ifVar method="equals" method-type="" name="w32running" name-type="" not="" not-type="" value="1" value-type="string"/>
      <openBlock/>
      <setVar name="w32running" name-type="" value="" value-type="string"/>
      <elementShow object="wincursor" object-type="object"/>
      <elementHide object="w93warning" object-type="object"/>
      <elementHide object="w93browser" object-type="object"/>
      <exit/>
      <closeBlock/>
      <elementSetX object="CtrlMpanel" object-type="object" relative="" relative-type="" value="16" value-type="integer"/>
      <elementSetY object="CtrlMpanel" object-type="object" relative="" relative-type="" value="16" value-type="integer"/>
      <phpLine expr="$this-&gt;CtrlMpanel-&gt;scaleX = 0" expr-type="expr"/>
      <phpLine expr="$this-&gt;CtrlMpanel-&gt;scaleY = 0" expr-type="expr"/>
      <phpLine expr="$scaleAnim = new ScaleAnimationBehaviour()" expr-type="expr"/>
      <phpLine expr="$scaleAnim-&gt;scale = 1.0" expr-type="expr"/>
      <phpLine expr="$scaleAnim-&gt;duration = 250" expr-type="expr"/>
      <phpLine expr="$scaleAnim-&gt;apply($this-&gt;CtrlMpanel)" expr-type="expr"/>
      <behaviourEnable behaviour="behaviour\custom\ScaleAnimationBehaviour" behaviour-type="string" object="CtrlMpanel" object-type="object"/>
      <elementToggle object="CtrlMpanel" object-type="object"/>
      <fadeTo continue="" continue-type="" duration="250" duration-type="integer" object="CtrlMpanel" object-type="object" value="1" value-type="float"/>
      <behaviourEnable behaviour="behaviour\custom\DropShadowEffectBehaviour" behaviour-type="string" object="CtrlMpanel" object-type="object"/>
      <behaviourDisable behaviour="behaviour\custom\ScaleAnimationBehaviour" behaviour-type="string" object="CtrlMpanel" object-type="object"/>
    </method>
  
  
