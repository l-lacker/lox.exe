  <method name="doHackenterAction">
      <elementSetText object="hacktext" object-type="object" relative="" relative-type="" value="Ты мудославина зачем жмёшь &quot;ввод&quot; если можно жать Enter??? Лишнюю кнопку я теперь заблокировал для тупых... Время ты своё не ценишь на перенаведение курсора на всякие говнокнопки..." value-type="string"/>
      <elementShow object="button4" object-type="object"/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <elementFocus object="hackedit" object-type="object"/>
    </method>
  <method name="doHackeditGlobalKeyDownEnter">
      <ifText method="equals" method-type="" not="" not-type="" object="~sender" object-type="object" string="" string-type="string"/>
      <openBlock/>
      <exit/>
      <closeBlock/>
      <elementEnabledOff object="~sender" object-type="object"/>
      <elementHide object="button4" object-type="object"/>
      <elementHide object="hacktext" object-type="object"/>
      <phpLine expr="$GLOBALS['lastsaved'] = uiText($e-&gt;sender)" expr-type="expr"/>
      <elementSetText object="hacktext" object-type="object" relative="" relative-type="" value="НЕТ ТАКОЙ КОМАНДЫ!!! (их кстати обязательно вводить с маленькой буквы)" value-type="string"/>
      <ifText method="equals" method-type="" not="" not-type="" object="~sender" object-type="object" string="help" string-type="string"/>
      <phpLine expr="Element::setText($this-&gt;hacktext, &quot;Помощь!!!\nloxver - версию узнать\npink - тему сменить\n\nИсполняемые файлы:\nmoney-hack.lox\naloflash.lox&quot;);" expr-type="expr"/>
      <ifText method="equals" method-type="" not="" not-type="" object="~sender" object-type="object" string="loxver" string-type="string"/>
      <phpLine expr="Element::setText($this-&gt;hacktext, &quot;lox, версия 9\nАвтор: l-lacker\nПриложение предоставлено в некоммерческих целях, не собирает никаких данных и регулируется через универсальное меню Ctrl+M. По всем вопросам вы можете связаться с автором, необходимые контактные данные предоставлены на ресурсе https://l-lacker.ru\nНекоторые элементы в приложении принадлежат Microsoft и показаны лишь в иллюстративных целях&quot;);" expr-type="expr"/>
      <ifText method="equals" method-type="" not="" not-type="" object="~sender" object-type="object" string="vovaflash.lox" string-type="string"/>
      <phpLine expr="Element::setText($this-&gt;hacktext, &quot;Мы понимаем, что хочется ввести эту команду по привычке, но всё же название бренда изменилось и следовательно название этой утилиты тоже&quot;);" expr-type="expr"/>
      <ifText method="equals" method-type="" not="" not-type="" object="~sender" object-type="object" string="elbrusblock" string-type="string"/>
      <openBlock/>
      <setVar name="blocktime" name-type="" value="2" value-type="string"/>
      <showForm form="blocked" form-type="form"/>
      <hideForm form="MainForm" form-type="form"/>
      <closeBlock/>
      <ifText method="equals" method-type="" not="" not-type="" object="~sender" object-type="object" string="pink" string-type="string"/>
      <openBlock/>
